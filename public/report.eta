<html>
  <head>
    <title>Retaining Wall Calculation Report</title>
  </head>
  <style>
    @page {
      size: A4 portrait;
      margin: 20mm;
    }

    table {
      border-collapse: collapse;
      margin: 8px 0;
    }

    th, td {
      border: 1px solid #9ca3af;
      padding: 4px 10px;
      text-align: left;
    }

    th {
      background: #f3f4f6;
    }

    .ok {
      color: #16a34a;
      font-weight: bold;
    }

    .not-ok {
      color: #dc2626;
      font-weight: bold;
    }

    .note {
      font-size: 0.85em;
      color: #6b7280;
    }

    .figure {
      margin: 8px 0;
      break-inside: avoid;
    }
  </style>


  <body style="font-family: Arial, sans-serif;">
    <h1>Retaining Wall Calculation Report</h1>
    <p>Name: <%= it.model.name %></p>
    <p>Author: <%= it.model.author %></p>
    <p>Date: <%= it.model.date %></p>

    <h2>Preview</h2>
    <%
      /* Cross-section figure, drawn per running metre in the model's mm units:
         y to the right from the toe, z up from the foundation base.
         SVG's y axis points down, so sy() flips z. */
      const m = it.model;
      const FREE = 1300;   // soil drawn beyond the foundation on both sides, mm
      const GAP = 300;     // gap between the soil edge and a pressure diagram, mm
      const DIAG = 900;    // width drawn for the largest pressure value, mm
      const LBL = 850;     // margin reserved for pressure value labels, mm

      const fL = m.foundation.left, fT = m.foundation.thickness;
      const wT = m.wall.thickness, wH = m.wall.height;
      const B = fL + wT + m.foundation.right;
      const tanA = Math.tan(m.slab.angle * Math.PI / 180);
      const leftEdge = -FREE, rightEdge = B + FREE;
      const rightW = rightEdge - (fL + wT);

      const layerGeom = (layers) => {
        let z = 0;
        return layers.map((l) => { const bottom = z; z += l.thickness; return { bottom, top: z }; });
      };
      const layersL = layerGeom(m.groundLeft), layersR = layerGeom(m.groundRight);
      const rightTop = layersR.length ? layersR[layersR.length - 1].top : 0;
      const slopedTop = rightTop + rightW * tanA;
      const slabTop = slopedTop + m.slab.thickness;

      const activeP = it.results.groundPressureRight.activePressure;
      const passiveP = it.results.groundPressureLeft.passivePressure;
      const maxP = Math.max(0.001,
        ...activeP.flatMap((p) => [p.bottom, p.top]),
        ...passiveP.flatMap((p) => [p.bottom, p.top]));
      const pScale = DIAG / maxP;

      const minY = leftEdge - GAP - DIAG - LBL, maxY = rightEdge + GAP + DIAG + LBL;
      const maxZ = Math.max(fT + wH, slabTop + 600) + 700;
      const sy = (z) => maxZ - z;

      const soilFills = ["#f0d9b5", "#e2bc8a", "#d4a066", "#c68445"];
      const soilColor = (id) => soilFills[Math.max(0, m.materials.findIndex((x) => x.id === id)) % soilFills.length];
      const matName = (id) => m.materials.find((x) => x.id === id)?.name ?? "?";
      const f1 = (n) => n.toFixed(1);

      const diagrams = [
        { layers: layersR, pressure: activeP, base: rightEdge + GAP, dir: 1,
          color: "#dc2626", marker: "rwf-active", caption: "Active pressure (K&#x2090;), kN/m&#178;" },
        { layers: layersL, pressure: passiveP, base: leftEdge - GAP, dir: -1,
          color: "#2563eb", marker: "rwf-passive", caption: "At-rest pressure (K&#8320;), kN/m&#178;" },
      ];
    %>
    <div class="figure">
      <svg viewBox="<%= minY %> 0 <%= maxY - minY %> <%= maxZ + 500 %>" width="100%" font-family="Arial, sans-serif" style="max-height: 130mm;">
        <defs>
          <marker id="rwf-active" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto"><path d="M0,0 L10,5 L0,10 z" fill="#dc2626"/></marker>
          <marker id="rwf-passive" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto"><path d="M0,0 L10,5 L0,10 z" fill="#2563eb"/></marker>
          <marker id="rwf-load" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto"><path d="M0,0 L10,5 L0,10 z" fill="#16a34a"/></marker>
        </defs>

        <!-- Soil layers (concrete is painted over the overlap, like the CSG cut in 3D) -->
        <% m.groundLeft.forEach((layer, i) => { const g = layersL[i]; %>
          <rect x="<%= leftEdge %>" y="<%= sy(g.top) %>" width="<%= fL - leftEdge %>" height="<%= g.top - g.bottom %>"
            fill="<%= soilColor(layer.materialId) %>" stroke="#a16207" stroke-width="12"/>
          <text x="<%= (leftEdge + fL) / 2 %>" y="<%= sy((g.bottom + g.top) / 2) + 55 %>" font-size="150" fill="#78350f" text-anchor="middle"><%= matName(layer.materialId) %></text>
        <% }) %>
        <% m.groundRight.forEach((layer, i) => { const g = layersR[i]; const topRightZ = i === m.groundRight.length - 1 ? slopedTop : g.top; %>
          <polygon points="<%= fL + wT %>,<%= sy(g.bottom) %> <%= rightEdge %>,<%= sy(g.bottom) %> <%= rightEdge %>,<%= sy(topRightZ) %> <%= fL + wT %>,<%= sy(g.top) %>"
            fill="<%= soilColor(layer.materialId) %>" stroke="#a16207" stroke-width="12"/>
          <text x="<%= fL + wT + rightW / 2 %>" y="<%= sy((g.bottom + g.top) / 2) + 55 %>" font-size="150" fill="#78350f" text-anchor="middle"><%= matName(layer.materialId) %></text>
        <% }) %>

        <!-- Concrete: foundation, wall stem, sloped slab -->
        <rect x="0" y="<%= sy(fT) %>" width="<%= B %>" height="<%= fT %>" fill="#b0b3b8" stroke="#4b5563" stroke-width="15"/>
        <rect x="<%= fL %>" y="<%= sy(fT + wH) %>" width="<%= wT %>" height="<%= wH %>" fill="#b0b3b8" stroke="#4b5563" stroke-width="15"/>
        <polygon points="<%= fL + wT %>,<%= sy(rightTop) %> <%= rightEdge %>,<%= sy(slopedTop) %> <%= rightEdge %>,<%= sy(slabTop) %> <%= fL + wT %>,<%= sy(rightTop + m.slab.thickness) %>"
          fill="#b0b3b8" stroke="#4b5563" stroke-width="15"/>

        <!-- Live load on the slab -->
        <% for (let i = 0; i <= 6; i++) { const y = fL + wT + rightW * i / 6; const zs = rightTop + m.slab.thickness + (y - fL - wT) * tanA; %>
          <line x1="<%= y %>" y1="<%= sy(zs + 500) %>" x2="<%= y %>" y2="<%= sy(zs + 60) %>" stroke="#16a34a" stroke-width="18" marker-end="url(#rwf-load)"/>
        <% } %>
        <text x="<%= fL + wT + rightW / 2 %>" y="<%= sy(slabTop + 750) %>" font-size="170" fill="#16a34a" text-anchor="middle">q&#8342; = <%= f1(m.q_k) %> kN/m&#178;</text>

        <!-- Pressure diagrams -->
        <% diagrams.forEach((d) => { const edge = (p) => d.base + d.dir * p * pScale; const anchor = d.dir === 1 ? "start" : "end"; %>
          <% d.layers.forEach((g, i) => { const p = d.pressure[i]; const h = g.top - g.bottom; %>
            <polygon points="<%= d.base %>,<%= sy(g.bottom) %> <%= edge(p.bottom) %>,<%= sy(g.bottom) %> <%= edge(p.top) %>,<%= sy(g.top) %> <%= d.base %>,<%= sy(g.top) %>"
              fill="<%= d.color %>" fill-opacity="0.15" stroke="<%= d.color %>" stroke-width="12"/>
            <% const n = Math.max(2, Math.round(h / 500)); for (let a = 0; a <= n; a++) {
                 const t = a / n; const z = g.bottom + t * h; const pv = p.bottom + t * (p.top - p.bottom);
                 if (pv * pScale < 120) continue; %>
              <line x1="<%= edge(pv) %>" y1="<%= sy(z) %>" x2="<%= d.base + d.dir * 70 %>" y2="<%= sy(z) %>" stroke="<%= d.color %>" stroke-width="14" marker-end="url(#<%= d.marker %>)"/>
            <% } %>
            <text x="<%= edge(p.bottom) + d.dir * 100 %>" y="<%= sy(g.bottom) + 50 %>" font-size="150" fill="<%= d.color %>" text-anchor="<%= anchor %>"><%= f1(p.bottom) %></text>
            <% if (i === d.layers.length - 1) { %>
              <text x="<%= edge(p.top) + d.dir * 100 %>" y="<%= sy(g.top) + 50 %>" font-size="150" fill="<%= d.color %>" text-anchor="<%= anchor %>"><%= f1(p.top) %></text>
            <% } %>
          <% }) %>
          <text x="<%= d.base + d.dir * (DIAG / 2 + 100) %>" y="<%= sy(maxZ - 350) %>" font-size="170" fill="<%= d.color %>" text-anchor="middle"><%~ d.caption %></text>
        <% }) %>

        <!-- Dimensions (mm); 45-degree ticks, engineering chain style -->
        <% const dimZ = -300; const chainYs = [0, fL, fL + wT, B]; %>
        <% chainYs.forEach((y) => { %>
          <line x1="<%= y %>" y1="<%= sy(0) %>" x2="<%= y %>" y2="<%= sy(dimZ - 80) %>" stroke="#9ca3af" stroke-width="8"/>
        <% }) %>
        <line x1="0" y1="<%= sy(dimZ) %>" x2="<%= B %>" y2="<%= sy(dimZ) %>" stroke="#6b7280" stroke-width="10"/>
        <% chainYs.forEach((y) => { %>
          <line x1="<%= y - 60 %>" y1="<%= sy(dimZ) + 60 %>" x2="<%= y + 60 %>" y2="<%= sy(dimZ) - 60 %>" stroke="#374151" stroke-width="12"/>
        <% }) %>
        <% [{ a: 0, b: fL }, { a: fL, b: fL + wT }, { a: fL + wT, b: B }].forEach((d) => { %>
          <text x="<%= (d.a + d.b) / 2 %>" y="<%= sy(dimZ) - 60 %>" font-size="140" fill="#374151" text-anchor="middle"><%= d.b - d.a %></text>
        <% }) %>
        <%
          const vDims = [
            // Wall height beside the stem, foundation thickness at the toe
            { za: fT, zb: fT + wH, at: fL - 250 },
            { za: 0, zb: fT, at: -250 },
            // Ground layer thicknesses at the outer soil edges
            ...layersL.map((g) => ({ za: g.bottom, zb: g.top, at: leftEdge + 250 })),
            ...layersR.map((g) => ({ za: g.bottom, zb: g.top, at: rightEdge - 250 })),
            // Slab thickness at its right end face
            { za: slopedTop, zb: slabTop, at: rightEdge + 150 },
          ];
        %>
        <% vDims.forEach((d) => { const mid = sy((d.za + d.zb) / 2); %>
          <line x1="<%= d.at %>" y1="<%= sy(d.za) %>" x2="<%= d.at %>" y2="<%= sy(d.zb) %>" stroke="#6b7280" stroke-width="10"/>
          <% [d.za, d.zb].forEach((z) => { %>
            <line x1="<%= d.at - 60 %>" y1="<%= sy(z) + 60 %>" x2="<%= d.at + 60 %>" y2="<%= sy(z) - 60 %>" stroke="#374151" stroke-width="12"/>
          <% }) %>
          <text x="<%= d.at - 100 %>" y="<%= mid %>" transform="rotate(-90 <%= d.at - 100 %> <%= mid %>)" font-size="140" fill="#374151" text-anchor="middle"><%= d.zb - d.za %></text>
        <% }) %>

        <!-- Slab angle: arc from a dashed horizontal reference to the slab top surface -->
        <%
          const angleVertex = { x: fL + wT, y: sy(rightTop + m.slab.thickness) };
          const arcR = 800;
          const angleRad = m.slab.angle * Math.PI / 180;
          const arcSweep = m.slab.angle >= 0 ? 0 : 1;
        %>
        <line x1="<%= angleVertex.x %>" y1="<%= angleVertex.y %>" x2="<%= angleVertex.x + arcR + 250 %>" y2="<%= angleVertex.y %>" stroke="#6b7280" stroke-width="10" stroke-dasharray="60 60"/>
        <path d="M <%= angleVertex.x + arcR %> <%= angleVertex.y %> A <%= arcR %> <%= arcR %> 0 0 <%= arcSweep %> <%= angleVertex.x + arcR * Math.cos(angleRad) %> <%= angleVertex.y - arcR * Math.sin(angleRad) %>" fill="none" stroke="#374151" stroke-width="12"/>
        <text x="<%= angleVertex.x + arcR + 350 %>" y="<%= angleVertex.y - arcR * Math.sin(angleRad / 2) %>" font-size="140" fill="#374151" text-anchor="start"><%= m.slab.angle %>&#176;</text>
      </svg>
    </div>

    <h2>Loads</h2>
    <p>Live load on slab q<sub>k</sub>: <%= it.model.q_k %> kN/m<sup>2</sup></p>
    <p>Permanent surcharge (slab self-weight) q<sub>perm</sub>: <%= it.results.q_perm.toFixed(1) %> kN/m<sup>2</sup></p>
    <p>Total surcharge q<sub>d</sub>: <%= it.results.q_d.toFixed(1) %> kN/m<sup>2</sup></p>

    <h2>Partial factors</h2>
    <p>Destabilizing load &gamma;<sub>G,dst</sub>: <%= it.model.gammaGdst %></p>
    <p>Variable load &gamma;<sub>Q,dst</sub>: <%= it.model.gammaQdst %></p>
    <p>Stabilizing load &gamma;<sub>G,stb</sub>: <%= it.model.gammaGstb %></p>
    <p>Sliding resistance &gamma;<sub>R,h</sub>: <%= it.model.gammaRh %></p>

    <h2>Materials</h2>
    <table>
      <thead>
        <tr>
          <th>Material</th>
          <th>Weight (kN/m<sup>3</sup>)</th>
          <th>Friction angle (&deg;)</th>
        </tr>
      </thead>
      <tbody>
        <% it.model.materials.forEach((mat) => { %>
          <tr>
            <td><%= mat.name %></td>
            <td><%= mat.weight %></td>
            <td><%= mat.phi %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <h2>Ground layers</h2>
    <% const materialName = (id) => { const m = it.model.materials.find((m) => m.id === id); return m ? m.name : "?"; } %>
    <h3>Left side (front)</h3>
    <table>
      <thead>
        <tr>
          <th>Layer (bottom to top)</th>
          <th>Material</th>
          <th>Thickness (mm)</th>
        </tr>
      </thead>
      <tbody>
        <% it.model.groundLeft.forEach((layer, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= materialName(layer.materialId) %></td>
            <td><%= layer.thickness %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <h3>Right side (backfill)</h3>
    <table>
      <thead>
        <tr>
          <th>Layer (bottom to top)</th>
          <th>Material</th>
          <th>Thickness (mm)</th>
        </tr>
      </thead>
      <tbody>
        <% it.model.groundRight.forEach((layer, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= materialName(layer.materialId) %></td>
            <td><%= layer.thickness %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <p>Soil under foundation: <%= materialName(it.model.foundationMaterialId) %></p>

    <h2>Results</h2>

    <h3>Overturning (EQU)</h3>
    <table>
      <tbody>
        <tr>
          <td>Active earth moment, permanent M<sub>a,perm</sub></td>
          <td><%= it.results.overturning.MaPerm.toFixed(1) %> kN&middot;m/m</td>
        </tr>
        <tr>
          <td>Active earth moment, variable M<sub>a,var</sub></td>
          <td><%= it.results.overturning.MaVar.toFixed(1) %> kN&middot;m/m</td>
        </tr>
        <tr>
          <td>Front earth resisting moment M<sub>p</sub></td>
          <td><%= it.results.overturning.Mp.toFixed(1) %> kN&middot;m/m</td>
        </tr>
        <tr>
          <td>Moment of weights M<sub>weights</sub></td>
          <td><%= it.results.overturning.Mweights.toFixed(1) %> kN&middot;m/m</td>
        </tr>
        <tr>
          <td>Design destabilizing moment M<sub>dst</sub> = &gamma;<sub>G,dst</sub>&middot;M<sub>a,perm</sub> + &gamma;<sub>Q,dst</sub>&middot;M<sub>a,var</sub></td>
          <td><%= it.results.overturning.Mdst.toFixed(1) %> kN&middot;m/m</td>
        </tr>
        <tr>
          <td>Design stabilizing moment M<sub>stb</sub> = &gamma;<sub>G,stb</sub>&middot;(M<sub>weights</sub> + M<sub>p</sub>)</td>
          <td><%= it.results.overturning.Mstb.toFixed(1) %> kN&middot;m/m</td>
        </tr>
        <tr>
          <td>Utilization M<sub>dst</sub> / M<sub>stb</sub></td>
          <% if (it.results.overturning.utilization < 1) { %>
            <td class="ok"><%= (it.results.overturning.utilization * 100).toFixed(0) %> % &mdash; OK</td>
          <% } else { %>
            <td class="not-ok"><%= Number.isFinite(it.results.overturning.utilization) ? (it.results.overturning.utilization * 100).toFixed(0) + " %" : "&infin;" %> &mdash; NOT OK</td>
          <% } %>
        </tr>
      </tbody>
    </table>

    <h3>Sliding</h3>
    <table>
      <tbody>
        <tr>
          <td>Active thrust, permanent E<sub>a,perm</sub></td>
          <td><%= it.results.sliding.EaPerm.toFixed(1) %> kN/m</td>
        </tr>
        <tr>
          <td>Active thrust, variable E<sub>a,var</sub></td>
          <td><%= it.results.sliding.EaVar.toFixed(1) %> kN/m</td>
        </tr>
        <tr>
          <td>Characteristic vertical force V<sub>k</sub></td>
          <td><%= it.results.sliding.Vk.toFixed(1) %> kN/m</td>
        </tr>
        <tr>
          <td>Base friction angle &delta;</td>
          <td><%= it.results.sliding.deltaDeg.toFixed(1) %>&deg;</td>
        </tr>
        <tr>
          <td>Design driving force H<sub>d</sub> = &gamma;<sub>G,dst</sub>&middot;E<sub>a,perm</sub> + &gamma;<sub>Q,dst</sub>&middot;E<sub>a,var</sub></td>
          <td><%= it.results.sliding.Hd.toFixed(1) %> kN/m</td>
        </tr>
        <tr>
          <td>Design resistance R<sub>d</sub> = &gamma;<sub>G,stb</sub>&middot;V<sub>k</sub>&middot;tan&delta; / &gamma;<sub>R,h</sub></td>
          <td><%= it.results.sliding.Rd.toFixed(1) %> kN/m</td>
        </tr>
        <tr>
          <td>Utilization H<sub>d</sub> / R<sub>d</sub></td>
          <% if (it.results.sliding.utilization < 1) { %>
            <td class="ok"><%= (it.results.sliding.utilization * 100).toFixed(0) %> % &mdash; OK</td>
          <% } else { %>
            <td class="not-ok"><%= Number.isFinite(it.results.sliding.utilization) ? (it.results.sliding.utilization * 100).toFixed(0) + " %" : "&infin;" %> &mdash; NOT OK</td>
          <% } %>
        </tr>
      </tbody>
    </table>

    <h3>Method notes</h3>
    <p class="note">Active earth pressure by Coulomb with wall friction &delta; = &phi;; the thrust is conservatively taken as fully horizontal.</p>
    <p class="note">Front-side earth resistance is modeled with the at-rest coefficient K<sub>0</sub> and neglected in the sliding check (EN 1997-1, 6.5.3(5)).</p>
    <p class="note">Sliding resistance for cast-in-place concrete: &delta; = &phi; of the soil under the foundation (EN 1997-1, 6.5.3).</p>
  </body>
</html>
